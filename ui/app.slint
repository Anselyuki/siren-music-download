import { Button, ListView, ProgressIndicator, ComboBox, LineEdit, HorizontalBox, VerticalBox } from "std-widgets.slint";

export struct AlbumItem {
    cid: string,
    name: string,
    artists: string,
    cover_url: string,
}

export struct SongItem {
    cid: string,
    name: string,
    artists: string,
    selected: bool,
}

export struct DownloadTask {
    song_name: string,
    progress: float,
    done: bool,
}

// ── Album card ──────────────────────────────────────────────────────────────
component AlbumCard inherits Rectangle {
    in property <AlbumItem> album;
    in property <bool> is_selected;
    callback clicked;

    background: is_selected ? #3d5afe : #1e1e2e;
    border-radius: 8px;
    height: 64px;

    TouchArea { clicked => { root.clicked(); } }

    HorizontalLayout {
        padding-top: 12px;
        padding-bottom: 12px;
        padding-left: 12px;
        padding-right: 12px;
        spacing: 10px;
        alignment: start;

        VerticalLayout {
            alignment: center;
            spacing: 2px;
            Text {
                text: album.name;
                color: is_selected ? #ffffff : #cdd6f4;
                font-size: 13px;
                font-weight: 600;
                overflow: elide;
            }
            Text {
                text: album.artists;
                color: is_selected ? #c0c8ff : #7c7f93;
                font-size: 11px;
                overflow: elide;
            }
        }
    }
}

// ── Song row ────────────────────────────────────────────────────────────────
component SongRow inherits Rectangle {
    in-out property <SongItem> song;
    callback toggled(bool);

    background: song.selected ? #1a2344 : transparent;
    border-radius: 4px;
    height: 44px;

    TouchArea {
        clicked => {
            song.selected = !song.selected;
            root.toggled(song.selected);
        }
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        alignment: space-between;

        VerticalLayout {
            alignment: center;
            Text {
                text: song.name;
                color: #cdd6f4;
                font-size: 13px;
                overflow: elide;
            }
            Text {
                text: song.artists;
                color: #7c7f93;
                font-size: 11px;
                overflow: elide;
            }
        }

        Rectangle {
            width: 20px;
            height: 20px;
            border-radius: 4px;
            background: song.selected ? #3d5afe : #313244;
            border-width: 1px;
            border-color: song.selected ? #3d5afe : #585b70;

            Text {
                text: song.selected ? "✓" : "";
                color: white;
                font-size: 14px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

// ── Task row ────────────────────────────────────────────────────────────────
component TaskRow inherits Rectangle {
    in property <DownloadTask> task;

    background: #1e1e2e;
    border-radius: 6px;
    height: 52px;

    VerticalLayout {
        padding-top: 8px;
        padding-bottom: 8px;
        padding-left: 12px;
        padding-right: 12px;
        spacing: 4px;

        HorizontalLayout {
            alignment: space-between;
            Text {
                text: task.song_name;
                color: #cdd6f4;
                font-size: 12px;
                overflow: elide;
            }
            Text {
                text: task.done ? "Done" : (Math.round(task.progress * 100) + "%");
                color: task.done ? #a6e3a1 : #89b4fa;
                font-size: 12px;
            }
        }

        ProgressIndicator { progress: task.progress; }
    }
}

// ── Main window ──────────────────────────────────────────────────────────────
export component AppWindow inherits Window {
    title: "Siren Music Download";
    background: #181825;
    min-width: 900px;
    min-height: 600px;
    preferred-width: 1100px;
    preferred-height: 700px;

    in-out property <[AlbumItem]> albums;
    in-out property <[SongItem]> songs;
    in-out property <[DownloadTask]> tasks;
    in-out property <int> selected_album_index: -1;
    in-out property <string> selected_album_name;
    in-out property <string> output_dir;
    in-out property <int> output_format_index: 0;
    in-out property <bool> loading_albums: false;
    in-out property <bool> loading_songs: false;
    in-out property <bool> downloading: false;
    in-out property <string> status_text;

    callback load_albums();
    callback select_album(int);
    callback toggle_song(int, bool);
    callback select_all_songs();
    callback deselect_all_songs();
    callback choose_output_dir();
    callback start_download();

    VerticalLayout {
        // ── Toolbar ────────────────────────────────────────────────────────
        Rectangle {
            background: #1e1e2e;
            height: 56px;

            HorizontalLayout {
                padding-top: 12px;
                padding-bottom: 12px;
                padding-left: 16px;
                padding-right: 16px;
                alignment: space-between;

                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    Text {
                        text: "Siren";
                        color: #cba6f7;
                        font-size: 18px;
                        font-weight: 800;
                        vertical-alignment: center;
                    }
                    Text {
                        text: "Music Download";
                        color: #cdd6f4;
                        font-size: 18px;
                        font-weight: 300;
                        vertical-alignment: center;
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;
                    Text {
                        text: "Format:";
                        color: #7c7f93;
                        font-size: 13px;
                        vertical-alignment: center;
                    }
                    ComboBox {
                        model: ["WAV (Lossless)", "FLAC (via ffmpeg)", "MP3"];
                        current-index <=> output_format_index;
                        width: 180px;
                    }
                    Button {
                        text: "Refresh";
                        clicked => { load_albums(); }
                    }
                }
            }
        }

        // ── Three-column body ───────────────────────────────────────────────
        HorizontalLayout {
            // Column 1 – Album list
            Rectangle {
                width: 280px;
                background: #181825;

                VerticalLayout {
                    padding-top: 12px;
                    padding-bottom: 12px;
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: 4px;

                    Text {
                        text: loading_albums ? "Loading albums…" : ("Albums (" + albums.length + ")");
                        color: #7c7f93;
                        font-size: 11px;
                        font-weight: 700;
                    }

                    ListView {
                        for album[i] in albums: AlbumCard {
                            album: album;
                            is_selected: i == selected_album_index;
                            clicked => { select_album(i); }
                        }
                    }
                }
            }

            // Column 2 – Song list
            Rectangle {
                width: 380px;
                background: #1e1e2e;

                VerticalLayout {
                    padding-top: 12px;
                    padding-bottom: 12px;
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: 6px;

                    Text {
                        text: loading_songs
                            ? "Loading…"
                            : (selected_album_name == "" ? "Select an album" : selected_album_name);
                        color: #cdd6f4;
                        font-size: 14px;
                        font-weight: 700;
                        overflow: elide;
                    }

                    HorizontalLayout {
                        spacing: 6px;
                        Button { text: "All";  clicked => { select_all_songs(); } }
                        Button { text: "None"; clicked => { deselect_all_songs(); } }
                    }

                    ListView {
                        for song[i] in songs: SongRow {
                            song: song;
                            toggled(checked) => { toggle_song(i, checked); }
                        }
                    }
                }
            }

            // Column 3 – Download / queue
            Rectangle {
                background: #181825;

                VerticalLayout {
                    padding-top: 12px;
                    padding-bottom: 12px;
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: 8px;

                    Text {
                        text: "DOWNLOAD";
                        color: #7c7f93;
                        font-size: 11px;
                        font-weight: 700;
                    }

                    HorizontalLayout {
                        spacing: 6px;
                        LineEdit {
                            text: output_dir;
                            placeholder-text: "Output directory…";
                            read-only: true;
                            horizontal-stretch: 1;
                        }
                        Button {
                            text: "Browse";
                            clicked => { choose_output_dir(); }
                        }
                    }

                    Button {
                        text: downloading ? "Downloading…" : "Download Selected";
                        enabled: !downloading && songs.length > 0;
                        primary: true;
                        clicked => { start_download(); }
                    }

                    Text {
                        text: status_text;
                        color: #a6e3a1;
                        font-size: 12px;
                        wrap: word-wrap;
                    }

                    Text {
                        text: "QUEUE (" + tasks.length + ")";
                        color: #7c7f93;
                        font-size: 11px;
                        font-weight: 700;
                    }

                    ListView {
                        for task in tasks: TaskRow { task: task; }
                    }
                }
            }
        }
    }
}
